# EODHD MCP Server Configuration

# =============================================================================
# Required: EODHD API Key
# =============================================================================
# Your EODHD API key for accessing financial data
# Get yours at: https://eodhd.com/register
EODHD_API_KEY=your_api_key_here

# =============================================================================
# Server Configuration
# =============================================================================
# Host to bind the server to
MCP_HOST=127.0.0.1

# Port to bind the server to
MCP_PORT=8000

# Path for legacy HTTP endpoint (only used in non-OAuth mode)
MCP_PATH=/mcp

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
